            <div class="clock-time" id="pst"></div>
            <div class="clock-zone">PST</div>
        </div>

        <div class="clock-container">
            <div class="clock-time" id="ist"></div>
            <div class="clock-zone">IST</div>
        </div>

    </div>

    <script>

    function updateClocks(){

        const options = {
            hour:'2-digit',
