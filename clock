    font-weight:bold;
    color:white;
    margin-bottom:8px;
    font-family:monospace;
    white-space:nowrap;
    overflow:hidden;
}

    .clock-zone{
        font-size:18px;
        color:#cccccc;
    }

    </style>

    <div class="clock-wrapper">

        <div class="clock-container">
            <div class="clock-time" id="est"></div>
